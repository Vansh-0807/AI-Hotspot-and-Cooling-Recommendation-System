OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Raipur-only live data (no demo / synthetic cities)
TARGET_CITY=Raipur
TARGET_LOCATION_QUERY=Raipur, Chhattisgarh, India
TARGET_BBOX=81.58,21.20,81.72,21.32
GRID_ROWS=8
GRID_COLS=8

# Local Python: use localhost. Docker Compose overrides host to `db`.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/urban_heat
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:8080,http://127.0.0.1:8080
